{
  "name": "codex-thread-inspector",
  "version": "0.1.0",
  "description": "Visualize Codex agent session internals — timeline, token usage, tool calls, and context layers",
  "type": "module",
  "bin": {
    "codex-thread-inspector": "./bin/cli.mjs"
  },
  "files": [
    ".next/standalone",
    ".next/static",
    "bin"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public 2>/dev/null || true",
    "start": "next start",
    "lint": "eslint",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "codex",
    "agent",
    "session",
    "inspector",
    "visualization",
    "jsonl",
    "cli"
  ],
  "author": "Jarrod Watts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jarrodwatts/codex-thread-inspector"
  },
  "homepage": "https://github.com/jarrodwatts/codex-thread-inspector",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "open": "^10.2.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
